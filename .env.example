# Environment Configuration Template

# Copy this file to .env and fill in your values
# This file should NOT be committed to git for security

# ==================== Flask Configuration ====================

# Environment (development, testing, production)
FLASK_ENV=development

# Secret key for sessions (change to random string in production)
# Generate with: python -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=dev-secret-key-change-this-in-production

# Debug mode (set to False in production)
DEBUG=True

# ==================== Database Configuration ====================

# Database URL (SQLite by default)
# For SQLite: sqlite:///database/helpdesk.db
# For PostgreSQL: postgresql://user:password@localhost/helpdesk
# For Oracle: oracle://user:password@localhost:1521/helpdesk
DATABASE_URL=sqlite:///database/helpdesk.db

# Database connection pool size
DB_POOL_SIZE=5

# Database pool recycle time (seconds)
DB_POOL_RECYCLE=3600

# ==================== Email Configuration (Optional) ====================

# Email provider (gmail, sendgrid, smtp)
MAIL_PROVIDER=smtp

# SMTP server
MAIL_SERVER=smtp.gmail.com

# SMTP port
MAIL_PORT=587

# Use TLS
MAIL_USE_TLS=True

# Email username/sender
MAIL_USERNAME=your-email@gmail.com

# Email password or app password
MAIL_PASSWORD=your-app-password

# Default sender email
MAIL_DEFAULT_SENDER=noreply@helpdesk-system.com

# ==================== Session Configuration ====================

# Session timeout in seconds (3600 = 1 hour)
PERMANENT_SESSION_LIFETIME=3600

# Session cookie settings
SESSION_COOKIE_SECURE=False  # Set to True in production with HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ==================== Security Configuration ====================

# Enable CSRF protection
WTF_CSRF_ENABLED=True

# Maximum content size in bytes (16MB)
MAX_CONTENT_LENGTH=16777216

# ==================== Application Configuration ====================

# Items per page in pagination
ITEMS_PER_PAGE=10

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Sentiment analysis thresholds
SENTIMENT_POSITIVE_THRESHOLD=0.1
SENTIMENT_NEGATIVE_THRESHOLD=-0.1

# ==================== Production Configuration ====================

# Server name (for URL generation)
SERVER_NAME=localhost:5000

# Preferred URL scheme (http or https)
PREFERRED_URL_SCHEME=http

# ==================== External Services (Optional) ====================

# API keys for external services
SENDGRID_API_KEY=your-sendgrid-api-key
SENTRY_DSN=your-sentry-dsn

# ==================== Testing Configuration ====================

# Test database (use in-memory for tests)
TEST_DATABASE_URL=sqlite:///:memory:

# Testing mode flag
TESTING=False
